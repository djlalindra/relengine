# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# The single login credential pair for this app.
APP_USERNAME=changeme
APP_PASSWORD=changeme-use-a-strong-password

# Random string, 32+ characters, used to sign session cookies.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Your OpenRouter API key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Public URL of your deployed app (used for OpenRouter attribution headers).
# Leave as localhost for local dev.
APP_URL=http://localhost:3000
